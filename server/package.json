{
  "name": "solar-planner-server",
  "version": "2.0.0",
  "description": "Solar Planner v2.0 - Node.js/Express/MongoDB Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "dev:trace": "node --trace-warnings -r ts-node/register src/server.ts",
    "dev:watch": "nodemon --exec ts-node src/server.ts",
    "check:relations": "ts-node src/scripts/checkRelations.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "solar",
    "energy",
    "planning",
    "mongodb",
    "express",
    "typescript"
  ],
  "author": "Solar Planner Team",
  "license": "MIT",
  "dependencies": {
    "@types/node-schedule": "^2.1.8",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "country-reverse-geocoding": "^0.2.2",
    "dotenv": "^16.4.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "geo-tz": "^8.1.6",
    "geolib": "^3.3.4",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.5.45",
    "mongoose": "^8.1.1",
    "node-schedule": "^2.1.1",
    "nodemailer": "^7.0.12",
    "pino": "^8.19.0",
    "prom-client": "^15.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.16",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vitest/ui": "^4.0.16",
    "eslint": "^8.56.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.0",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
