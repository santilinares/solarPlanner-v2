# Server Configuration
PORT=1235
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/solarplanner

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXP=15m

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend Configuration
FRONTEND_URL=http://localhost:4200

# Security
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXP=7d

# External APIs
# Open-Meteo and PVGIS require no API key.
# ENTSO-E: required for electricity price lookups (free registration at transparency.entsoe.eu)
ENTSOE_API_KEY=your-entsoe-api-key

# Production data refresh settings (all required)
PRODUCTION_REFRESH_THRESHOLD_H=6
PRODUCTION_HISTORY_DAYS=7
PRODUCTION_FORECAST_DAYS=10
