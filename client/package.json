{
  "name": "solar-planner-client",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve": "ng serve",
    "dev": "ng serve --configuration development",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\""
  },
  "author": "Santiago Linares Oliveira",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/platform-browser": "21.2.17",
    "@angular/platform-browser-dynamic": "21.2.17",
    "@angular/router": "21.2.17",
    "@primeuix/themes": "^2.0.3",
    "@turf/turf": "^7.0.0",
    "highcharts": "^11.2.0",
    "highcharts-angular": "^4.0.0",
    "jspdf": "^4.1.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "21.1.9",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.15",
    "@angular/cli": "21.2.15",
    "@angular/compiler-cli": "21.2.17",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.8",
    "@types/leaflet-draw": "^1.0.11",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.5",
    "prettier": "^3.1.1",
    "typescript": "~5.9.0"
  }
